{
  "name": "ghst",
  "version": "0.3.0",
  "description": "Free, open-source live system-audio transcription overlay with AI copilot — a Cluely / Parakeet alternative powered by Groq Whisper. Linux/PipeWire, transparent always-on-top window.",
  "keywords": [
    "electron",
    "transcription",
    "live-captions",
    "speech-to-text",
    "whisper",
    "groq",
    "vad",
    "silero-vad",
    "pipewire",
    "linux",
    "overlay",
    "always-on-top",
    "meeting-assistant",
    "copilot",
    "ai-copilot",
    "cluely-alternative",
    "parakeet-alternative",
    "open-source"
  ],
  "author": {
    "name": "Borislav Novikov",
    "email": "bnovikov012@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/bnovik0v/ghst",
  "repository": {
    "type": "git",
    "url": "https://github.com/bnovik0v/ghst.git"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev -- --no-sandbox",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "npm run build && electron-builder",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:dir": "npm run build && electron-builder --dir",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^8.0.2",
    "@types/node": "^22.10.0",
    "@vitest/ui": "^2.1.8",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "happy-dom": "^15.11.7",
    "release-it": "^17.11.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@ricky0123/vad-web": "^0.0.30",
    "dotenv": "^16.4.7",
    "onnxruntime-web": "^1.20.1"
  },
  "build": {
    "appId": "com.polaro.ghst",
    "productName": "ghst",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!**/node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!**/*.{ts,tsx,map}",
      "!**/.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}"
    ],
    "extraResources": [],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "AudioVideo",
      "synopsis": "Live system-audio transcription overlay",
      "description": "Captures system audio via PipeWire, runs Silero VAD, and streams to Groq Whisper for live captions in a transparent always-on-top overlay.",
      "maintainer": "Borislav Novikov <bnovikov012@gmail.com>",
      "vendor": "Borislav Novikov",
      "executableName": "ghst"
    },
    "deb": {
      "depends": [
        "pipewire-bin",
        "pulseaudio-utils",
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libdrm2",
        "libgbm1",
        "libasound2"
      ],
      "artifactName": "${productName}_${arch}.deb"
    },
    "appImage": {
      "artifactName": "${productName}-${arch}.AppImage"
    }
  }
}
